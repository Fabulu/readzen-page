[{"trad":"恍","simp":"恍","pinyin":"huang3","defs":["(bound form) in a hazy state of mind","(bound form) to snap out of that state","used in 恍如[huang3 ru2] and 恍若[huang3 ruo4]"]},{"trad":"恍如","simp":"恍如","pinyin":"huang3 ru2","defs":["to be as if...","to be rather like..."]},{"trad":"恍如隔世","simp":"恍如隔世","pinyin":"huang3 ru2 ge2 shi4","defs":["like a thing of the previous generation; as if it were a lifetime ago"]},{"trad":"恍忽","simp":"恍忽","pinyin":"huang3 hu1","defs":["variant of 恍惚[huang3 hu1]"]},{"trad":"恍惚","simp":"恍惚","pinyin":"huang3 hu1","defs":["absent-minded","distracted","dazzled","vaguely","dimly"]},{"trad":"恍然","simp":"恍然","pinyin":"huang3 ran2","defs":["suddenly (perceive)","confused; vague; distracted"]},{"trad":"恍然大悟","simp":"恍然大悟","pinyin":"huang3 ran2 da4 wu4","defs":["(idiom) to suddenly realize; to suddenly see the light"]},{"trad":"恍然醒悟","simp":"恍然醒悟","pinyin":"huang3 ran2 xing3 wu4","defs":["a sudden realization","to realize sth in a flash"]},{"trad":"恍神","simp":"恍神","pinyin":"huang3 shen2","defs":["to be off in another world","to suffer a lapse in concentration"]},{"trad":"恍若","simp":"恍若","pinyin":"huang3 ruo4","defs":["as if","as though","rather like"]},{"trad":"恍若隔世","simp":"恍若隔世","pinyin":"huang3 ruo4 ge2 shi4","defs":["see 恍如隔世[huang3 ru2 ge2 shi4]"]}]