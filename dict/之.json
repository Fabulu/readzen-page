[{"trad":"之","simp":"之","pinyin":"zhi1","defs":["(possessive particle, literary equivalent of 的[de5])","him","her","it"]},{"trad":"之一","simp":"之一","pinyin":"zhi1 yi1","defs":["one of (sth)","one out of a multitude","one (third, quarter, percent etc)"]},{"trad":"之上","simp":"之上","pinyin":"zhi1 shang4","defs":["above"]},{"trad":"之下","simp":"之下","pinyin":"zhi1 xia4","defs":["under","beneath","less than"]},{"trad":"之中","simp":"之中","pinyin":"zhi1 zhong1","defs":["inside","among","in the midst of (doing sth)","during"]},{"trad":"之乎者也","simp":"之乎者也","pinyin":"zhi1 hu1 zhe3 ye3","defs":["lit. 之[zhi1], 乎[hu1], 者[zhe3] and 也[ye3] (four grammatical particles of Classical Chinese) (idiom)","fig. archaic expressions"]},{"trad":"之內","simp":"之内","pinyin":"zhi1 nei4","defs":["inside; within"]},{"trad":"之前","simp":"之前","pinyin":"zhi1 qian2","defs":["before","prior to","ago","previously","beforehand"]},{"trad":"之外","simp":"之外","pinyin":"zhi1 wai4","defs":["outside","excluding"]},{"trad":"之字形","simp":"之字形","pinyin":"zhi1 zi4 xing2","defs":["Z-shaped; zigzag"]},{"trad":"之字路","simp":"之字路","pinyin":"zhi1 zi4 lu4","defs":["zigzag road","switchback"]},{"trad":"之後","simp":"之后","pinyin":"zhi1 hou4","defs":["after; behind","(at the beginning of a sentence) afterwards; since then"]},{"trad":"之所以","simp":"之所以","pinyin":"zhi1 suo3 yi3","defs":["(after a noun N and before a predicate P) the reason why N P","Example: 我之所以討厭他|我之所以讨厌他[wo3 zhi1 suo3 yi3 tao3 yan4 ta1] \"the reason why I dislike him (is ...)\""]},{"trad":"之至","simp":"之至","pinyin":"zhi1 zhi4","defs":["extremely"]},{"trad":"之間","simp":"之间","pinyin":"zhi1 jian1","defs":["(after a noun) between; among; amid","(used after certain bisyllabic words to form expressions indicating a short period of time, e.g. 彈指之間|弹指之间[tan2 zhi3 zhi1 jian1])"]},{"trad":"之際","simp":"之际","pinyin":"zhi1 ji4","defs":["during","at the time of"]},{"trad":"之類","simp":"之类","pinyin":"zhi1 lei4","defs":["and so on","and such"]}]