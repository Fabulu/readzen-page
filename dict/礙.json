[{"trad":"礙","simp":"碍","pinyin":"ai4","defs":["to hinder","to obstruct","to block"]},{"trad":"礙事","simp":"碍事","pinyin":"ai4 shi4","defs":["to be in the way; to be a hindrance","(usu. in the negative) to be of consequence; to matter"]},{"trad":"礙口","simp":"碍口","pinyin":"ai4 kou3","defs":["to shy to speak out","tongue-tied","to hesitate","too embarrassing for words"]},{"trad":"礙口識羞","simp":"碍口识羞","pinyin":"ai4 kou3 shi2 xiu1","defs":["tongue-tied for fear of embarrassment (idiom)"]},{"trad":"礙手礙腳","simp":"碍手碍脚","pinyin":"ai4 shou3 ai4 jiao3","defs":["(idiom) to be in the way; to be a hindrance"]},{"trad":"礙於","simp":"碍于","pinyin":"ai4 yu2","defs":["to be constrained by; due to (a constraining factor)"]},{"trad":"礙眼","simp":"碍眼","pinyin":"ai4 yan3","defs":["to be an irksome presence (i.e. sth or sb one wishes were not there)"]},{"trad":"礙胃口","simp":"碍胃口","pinyin":"ai4 wei4 kou3","defs":["to impair the appetite"]},{"trad":"礙難","simp":"碍难","pinyin":"ai4 nan2","defs":["inconvenient","difficult for some reason","to find sth embarrassing"]},{"trad":"礙難從命","simp":"碍难从命","pinyin":"ai4 nan2 cong2 ming4","defs":["difficult to obey orders (idiom); much to my embarrassment, I am unable to comply"]},{"trad":"礙面子","simp":"碍面子","pinyin":"ai4 mian4 zi5","defs":["(not do sth) for fear of offending sb"]}]