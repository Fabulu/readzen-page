[{"trad":"逍","simp":"逍","pinyin":"xiao1","defs":["used in 逍遙|逍遥[xiao1 yao2]"]},{"trad":"逍遙","simp":"逍遥","pinyin":"xiao1 yao2","defs":["free and unfettered"]},{"trad":"逍遙法外","simp":"逍遥法外","pinyin":"xiao1 yao2 fa3 wai4","defs":["unfettered and beyond the law (idiom); evading retribution","getting away with it (e.g. crimes)","still at large"]},{"trad":"逍遙自在","simp":"逍遥自在","pinyin":"xiao1 yao2 zi4 zai5","defs":["free and at leisure (idiom); unfettered","outside the reach of the law (of criminal)","at large"]},{"trad":"逍遙自得","simp":"逍遥自得","pinyin":"xiao1 yao2 zi4 de2","defs":["doing as one pleases (idiom); foot-loose and fancy free"]}]