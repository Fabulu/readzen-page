efs":["to follow the trend"]},{"trad":"趕海","simp":"赶海","pinyin":"gan3 hai3","defs":["(dialect) to gather seafood at the beach while the tide is out; to comb the beach for shellfish, crabs or other marine life"]},{"trad":"趕盡殺絕","simp":"赶尽杀绝","pinyin":"gan3 jin4 sha1 jue2","defs":["to kill to the last one (idiom)","to exterminate","to eradicate","ruthless"]},{"trad":"趕緊","simp":"赶紧","pinyin":"gan3 jin3","defs":["hurriedly","without delay"]},{"trad":"趕羊","simp":"赶羊","pinyin":"gan3 yang2","defs":["to drive sheep","to herd sheep"]},{"trad":"趕考","simp":"赶考","pinyin":"gan3 kao3","defs":["to go and take an imperial examination"]},{"trad":"趕腳","simp":"赶脚","pinyin":"gan3 jiao3","defs":["to work as a carter or porter","to transport goods for a living (esp. by donkey)"]},{"trad":"趕英超美","simp":"赶英超美","pinyin":"gan3 Ying1 chao1 Mei3","defs":["to catch up with England and surpass the USA (economic goal)"]},{"trad":"趕走","simp":"赶走","pinyin":"gan3 zou3","defs":["to drive out","to turn back"]},{"trad":"趕赴","simp":"赶赴","pinyin":"gan3 fu4","defs":["to hurry","to rush"]},{"trad":"趕超","simp":"赶超","pinyin":"gan3 chao1","defs":["to overtake"]},{"trad":"趕跑","simp":"赶跑","pinyin":"gan3 pao3","defs":["to drive away","to force out","to repel"]},{"trad":"趕路","simp":"赶路","pinyin":"gan3 lu4","defs":["to hasten on with one's journey","to hurry on"]},{"trad":"趕車","simp":"赶车","pinyin":"gan3 che1","defs":["to drive a cart"]},{"trad":"趕集","simp":"赶集","pinyin":"gan3 ji2","defs":["to go to a local market or country fair (on market day)"]},{"trad":"趕鴨子上架","simp":"赶鸭子上架","pinyin":"gan3 ya1 zi5 shang4 jia4","defs":["lit. to drive a duck onto a perch (idiom)","fig. to push sb to do sth way beyond their ability"]}]