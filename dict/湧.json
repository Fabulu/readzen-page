[{"trad":"湧","simp":"涌","pinyin":"yong3","defs":["to bubble up","to rush forth"]},{"trad":"湧入","simp":"涌入","pinyin":"yong3 ru4","defs":["to come pouring in","influx"]},{"trad":"湧出","simp":"涌出","pinyin":"yong3 chu1","defs":["to gush","to gush out","to pour out"]},{"trad":"湧動","simp":"涌动","pinyin":"yong3 dong4","defs":["(of water, people, thoughts etc) to surge; to well up and flow; to move in waves"]},{"trad":"湧泉","simp":"涌泉","pinyin":"yong3 quan2","defs":["gushing spring","see 湧泉穴|涌泉穴[yong3 quan2 xue2]"]},{"trad":"湧泉穴","simp":"涌泉穴","pinyin":"yong3 quan2 xue2","defs":["(TCM) acupuncture point KI-1, located on the sole"]},{"trad":"湧流","simp":"涌流","pinyin":"yong3 liu2","defs":["to gush","to spurt"]},{"trad":"湧浪","simp":"涌浪","pinyin":"yong3 lang4","defs":["swell","billows","surging waves"]},{"trad":"湧溢","simp":"涌溢","pinyin":"yong3 yi4","defs":["to well up","to spill out (of water from a spring)"]},{"trad":"湧現","simp":"涌现","pinyin":"yong3 xian4","defs":["to emerge in large numbers","to spring up","to emerge prominently"]},{"trad":"湧起","simp":"涌起","pinyin":"yong3 qi3","defs":["to well up","to boil out","to bubble forth","to spurt"]},{"trad":"湧進","simp":"涌进","pinyin":"yong3 jin4","defs":["to spill","to overflow (of water, crowds)","to crowd (into a space)"]}]