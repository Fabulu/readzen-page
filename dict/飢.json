[{"trad":"飢","simp":"饥","pinyin":"ji1","defs":["(bound form) hungry"]},{"trad":"飢不擇食","simp":"饥不择食","pinyin":"ji1 bu4 ze2 shi2","defs":["when hungry, you can't pick what you eat (idiom); beggars can't be choosers","When matters are urgent, don't spend time choosing alternatives."]},{"trad":"飢寒交迫","simp":"饥寒交迫","pinyin":"ji1 han2 jiao1 po4","defs":["beset by hunger and cold (idiom)","starving and freezing","in desperate poverty"]},{"trad":"飢渴","simp":"饥渴","pinyin":"ji1 ke3","defs":["hungry and thirsty","(fig.) to crave (knowledge, love etc)"]},{"trad":"飢腸轆轆","simp":"饥肠辘辘","pinyin":"ji1 chang2 lu4 lu4","defs":["(idiom) stomach rumbling with hunger; very hungry"]},{"trad":"飢餓","simp":"饥饿","pinyin":"ji1 e4","defs":["hunger","starvation","famine"]}]