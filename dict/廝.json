[{"trad":"廝","simp":"厮","pinyin":"si1","defs":["(bound form) together; each other","(bound form) male servant","(bound form) dude; so-and-so (used in 那廝|那厮[na4 si1] and 這廝|这厮[zhe4 si1])"]},{"trad":"廝守","simp":"厮守","pinyin":"si1 shou3","defs":["to stay together; to rely on one another"]},{"trad":"廝打","simp":"厮打","pinyin":"si1 da3","defs":["to come to blows; to tussle"]},{"trad":"廝搏","simp":"厮搏","pinyin":"si1 bo2","defs":["to come to blows; to fight; to tussle"]},{"trad":"廝殺","simp":"厮杀","pinyin":"si1 sha1","defs":["to fight at close quarters; to fight tooth and nail"]},{"trad":"廝混","simp":"厮混","pinyin":"si1 hun4","defs":["(derog.) to hang out (with sb)","to mix (things) together"]},{"trad":"廝熟","simp":"厮熟","pinyin":"si1 shu2","defs":["familiar with one another"]},{"trad":"廝纏","simp":"厮缠","pinyin":"si1 chan2","defs":["to pester"]},{"trad":"廝鑼","simp":"厮锣","pinyin":"si1 luo2","defs":["small gong"]}]