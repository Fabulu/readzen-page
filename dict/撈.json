[{"trad":"撈","simp":"捞","pinyin":"lao1","defs":["to fish up","to dredge up"]},{"trad":"撈一把","simp":"捞一把","pinyin":"lao1 yi1 ba3","defs":["to profiteer","to gain some underhand advantage"]},{"trad":"撈什子","simp":"捞什子","pinyin":"lao1 shi2 zi5","defs":["encumbrance","burden","that awful thing (colloquial)","nuisance"]},{"trad":"撈取","simp":"捞取","pinyin":"lao1 qu3","defs":["to dredge up; to scoop up from the water","to fish for; to gain (by improper means)"]},{"trad":"撈外快","simp":"捞外快","pinyin":"lao1 wai4 kuai4","defs":["to make extra money"]},{"trad":"撈女","simp":"捞女","pinyin":"lao1 nu:3","defs":["(slang) gold digger; woman who pursues men for money"]},{"trad":"撈本","simp":"捞本","pinyin":"lao1 ben3","defs":["to get one's money back (esp. gambling)","to recoup one's losings"]},{"trad":"撈油水","simp":"捞油水","pinyin":"lao1 you2 shui3","defs":["(coll.) to gain profit (usu. by underhand means)"]},{"trad":"撈稻草","simp":"捞稻草","pinyin":"lao1 dao4 cao3","defs":["(fig.) to clutch at straws (in desperation)","to take advantage of the situation (unscrupulously)"]},{"trad":"撈錢","simp":"捞钱","pinyin":"lao1 qian2","defs":["lit. to dredge for money","to make money by reprehensible means","to fish for a quick buck"]}]