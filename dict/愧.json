[{"trad":"愧","simp":"愧","pinyin":"kui4","defs":["ashamed"]},{"trad":"愧不敢當","simp":"愧不敢当","pinyin":"kui4 bu4 gan3 dang1","defs":["lit. I'm ashamed and dare not (accept the honor); fig. I do not deserve your praise.","You flatter me too much."]},{"trad":"愧對","simp":"愧对","pinyin":"kui4 dui4","defs":["to be ashamed to face (sb)","to feel bad about having failed (sb)"]},{"trad":"愧怍","simp":"愧怍","pinyin":"kui4 zuo4","defs":["ashamed"]},{"trad":"愧恨","simp":"愧恨","pinyin":"kui4 hen4","defs":["ashamed and sorry","suffering shame and remorse"]},{"trad":"愧悔無地","simp":"愧悔无地","pinyin":"kui4 hui3 wu2 di4","defs":["ashamed and unable to show one's face (idiom)"]},{"trad":"愧汗","simp":"愧汗","pinyin":"kui4 han4","defs":["sweating from shame","extremely ashamed"]},{"trad":"愧疚","simp":"愧疚","pinyin":"kui4 jiu4","defs":["to feel guilty; to feel ashamed of oneself; to be remorseful"]},{"trad":"愧色","simp":"愧色","pinyin":"kui4 se4","defs":["ashamed look"]},{"trad":"愧赧","simp":"愧赧","pinyin":"kui4 nan3","defs":["to blush in shame","red-faced"]}]